      {
        "name": "HR Measures",
        "lineageTag": "0e4a4894-ff01-4cf8-9f5a-00486fddc733",
        "columns": [
          {
            "name": "Col",
            "dataType": "int64",
            "sourceColumn": "Col",
            "lineageTag": "bd617a73-aeda-4e0b-9bd2-e864377ee283",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "isHidden": true
          }
        ],
        "partitions": [
          {
            "name": "HR Measures",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #table ( type table [ Col = Int64.Type ], {} )",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Headcount",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    COUNTROWS ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ) )"
            ],
            "lineageTag": "ebb88939-5cc8-46ab-8618-c53a1a1ea631",
            "formatString": "#,0",
            "displayFolder": "Workforce"
          },
          {
            "name": "Saudi Headcount",
            "expression": [
              "CALCULATE ( [Headcount], Employees[NationalityGroup] = \"Saudi\" )"
            ],
            "lineageTag": "53c341d5-97ca-43cf-83d7-8c7c0828fd10",
            "formatString": "#,0",
            "displayFolder": "Saudization"
          },
          {
            "name": "Non-Saudi Headcount",
            "expression": [
              "[Headcount] - [Saudi Headcount]"
            ],
            "lineageTag": "8165e71b-bb75-4a12-8498-58b113a5b1ea",
            "formatString": "#,0",
            "displayFolder": "Saudization"
          },
          {
            "name": "Saudization %",
            "expression": [
              "DIVIDE ( [Saudi Headcount], [Headcount] )"
            ],
            "lineageTag": "54d79d81-ae95-45f7-a5fd-cb5fefb7e6ae",
            "formatString": "0.0%",
            "displayFolder": "Saudization"
          },
          {
            "name": "Saudization Target",
            "expression": [
              "0.40"
            ],
            "lineageTag": "0fca3081-b6f4-4cdf-9ddb-e55ccadc00c2",
            "formatString": "0%",
            "displayFolder": "Saudization"
          },
          {
            "name": "Female Headcount",
            "expression": [
              "CALCULATE ( [Headcount], Employees[Gender] = \"Female\" )"
            ],
            "lineageTag": "9ceb8feb-f83b-4ed5-9405-ad5c8d47f9d3",
            "formatString": "#,0",
            "displayFolder": "Workforce"
          },
          {
            "name": "Female Ratio %",
            "expression": [
              "DIVIDE ( [Female Headcount], [Headcount] )"
            ],
            "lineageTag": "ff7fffe0-23a5-420f-982b-975c8d9f4756",
            "formatString": "0.0%",
            "displayFolder": "Workforce"
          },
          {
            "name": "Hires",
            "expression": [
              "COUNTROWS ( FILTER ( Employees, Employees[HireDate] >= MIN ( 'Date'[Date] ) && Employees[HireDate] <= MAX ( 'Date'[Date] ) ) )"
            ],
            "lineageTag": "11c26551-9ba7-439e-a5a8-1291c4869e03",
            "formatString": "#,0",
            "displayFolder": "Attrition"
          },
          {
            "name": "Terminations",
            "expression": [
              "COUNTROWS ( FILTER ( Employees, NOT ISBLANK ( Employees[TerminationDate] ) && Employees[TerminationDate] >= MIN ( 'Date'[Date] ) && Employees[TerminationDate] <= MAX ( 'Date'[Date] ) ) )"
            ],
            "lineageTag": "165be5cb-843f-44f6-983d-0838a843ed26",
            "formatString": "#,0",
            "displayFolder": "Attrition"
          },
          {
            "name": "Voluntary Terminations",
            "expression": [
              "CALCULATE ( [Terminations], Employees[TerminationType] = \"Voluntary\" )"
            ],
            "lineageTag": "1e20e87a-50c3-490d-ada6-49cb016153cc",
            "formatString": "#,0",
            "displayFolder": "Attrition"
          },
          {
            "name": "Voluntary Share %",
            "expression": [
              "DIVIDE ( [Voluntary Terminations], [Terminations] )"
            ],
            "lineageTag": "b7ce9d10-d7dd-4327-aa3b-03134e9dc17a",
            "formatString": "0.0%",
            "displayFolder": "Attrition"
          },
          {
            "name": "Attrition Rate %",
            "expression": [
              "DIVIDE ( [Terminations], AVERAGEX ( VALUES ( 'Date'[MonthStart] ), [Headcount] ) )"
            ],
            "lineageTag": "ef5bf2e7-fae3-4aa1-8ff8-813cfaccf623",
            "formatString": "0.0%",
            "displayFolder": "Attrition"
          },
          {
            "name": "Net Headcount Change",
            "expression": [
              "[Hires] - [Terminations]"
            ],
            "lineageTag": "56cdc133-9eba-416e-8148-e9a39f3fe86d",
            "formatString": "+#,0;-#,0;0",
            "displayFolder": "Attrition"
          },
          {
            "name": "Avg Tenure (Years)",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    AVERAGEX ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ), DATEDIFF ( Employees[HireDate], _d, DAY ) / 365.25 )"
            ],
            "lineageTag": "41f93c0d-a0b7-4dfe-bd23-d51a04fc6c80",
            "formatString": "0.0",
            "displayFolder": "Workforce"
          },
          {
            "name": "Avg Age",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    AVERAGEX ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ), DATEDIFF ( Employees[BirthDate], _d, DAY ) / 365.25 )"
            ],
            "lineageTag": "83273126-3065-4da5-854b-b7565cd08559",
            "formatString": "0.0",
            "displayFolder": "Workforce"
          },
          {
            "name": "Monthly Payroll (SAR)",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    SUMX ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ), Employees[MonthlySalarySAR] )"
            ],
            "lineageTag": "2f420ebc-7671-477d-b2e7-c94dacd4546f",
            "formatString": "#,0",
            "displayFolder": "Compensation"
          },
          {
            "name": "Avg Monthly Salary (SAR)",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    AVERAGEX ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ), Employees[MonthlySalarySAR] )"
            ],
            "lineageTag": "4f9ce7ea-055d-42be-a00c-f03a46a5baf8",
            "formatString": "#,0",
            "displayFolder": "Compensation"
          },
          {
            "name": "Median Salary (SAR)",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    MEDIANX ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ), Employees[MonthlySalarySAR] )"
            ],
            "lineageTag": "9570106f-b061-497a-8ec0-df99adaf8262",
            "formatString": "#,0",
            "displayFolder": "Compensation"
          },
          {
            "name": "Avg Performance Rating",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "RETURN",
              "    AVERAGEX ( FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) ), Employees[PerformanceRating] )"
            ],
            "lineageTag": "307f3689-7f11-4609-bf07-9c126f536888",
            "formatString": "0.00",
            "displayFolder": "Performance"
          },
          {
            "name": "High Performers %",
            "expression": [
              " ",
              "VAR _d = MAX ( 'Date'[Date] )",
              "VAR _act = FILTER ( Employees, Employees[HireDate] <= _d && ( ISBLANK ( Employees[TerminationDate] ) || Employees[TerminationDate] > _d ) )",
              "RETURN",
              "    DIVIDE ( COUNTROWS ( FILTER ( _act, Employees[PerformanceRating] >= 4.5 ) ), COUNTROWS ( _act ) )"
            ],
            "lineageTag": "2bcf7230-968d-40b0-917f-6dc328aaa667",
            "formatString": "0.0%",
            "displayFolder": "Performance"
          },
          {
            "name": "Open Positions",
            "expression": [
              "CALCULATE ( COUNTROWS ( Recruitment ), Recruitment[Status] = \"Open\" )"
            ],
            "lineageTag": "2758f035-34e5-4f7b-ae23-db311218ebc4",
            "formatString": "#,0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Positions Filled",
            "expression": [
              "CALCULATE ( COUNTROWS ( Recruitment ), Recruitment[Status] = \"Filled\" )"
            ],
            "lineageTag": "dc5a162c-d587-4799-9afe-03bdc8b10e15",
            "formatString": "#,0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Avg Time to Fill (Days)",
            "expression": [
              "CALCULATE ( AVERAGE ( Recruitment[DaysToFill] ), Recruitment[Status] = \"Filled\" )"
            ],
            "lineageTag": "858332bb-2761-4486-b422-c8c1e4440497",
            "formatString": "0.0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Total Applications",
            "expression": [
              "SUM ( Recruitment[Applications] )"
            ],
            "lineageTag": "f8f5caf9-5597-47b5-81d4-0ee49653d13f",
            "formatString": "#,0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Offers Made",
            "expression": [
              "SUM ( Recruitment[OffersMade] )"
            ],
            "lineageTag": "82c66c94-3fc3-470d-baa0-078fab63bcb8",
            "formatString": "#,0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Offers Accepted",
            "expression": [
              "SUM ( Recruitment[OffersAccepted] )"
            ],
            "lineageTag": "3376681e-7f85-48bd-a73b-7faea02bbbbd",
            "formatString": "#,0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Offer Acceptance %",
            "expression": [
              "DIVIDE ( [Offers Accepted], [Offers Made] )"
            ],
            "lineageTag": "a1398522-b2df-45f5-8b58-15184e532548",
            "formatString": "0.0%",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Applications per Hire",
            "expression": [
              "DIVIDE ( [Total Applications], [Positions Filled] )"
            ],
            "lineageTag": "701f7bbd-9b0d-4649-97db-3b6d3666a369",
            "formatString": "0.0",
            "displayFolder": "Recruitment"
          },
          {
            "name": "Training Hours",
            "expression": [
              "SUM ( Training[Hours] )"
            ],
            "lineageTag": "45294810-04e4-4ef2-b124-b1a8a2ba5dbf",
            "formatString": "#,0",
            "displayFolder": "Training"
          },
          {
            "name": "Training Cost (SAR)",
            "expression": [
              "SUM ( Training[CostSAR] )"
            ],
            "lineageTag": "01fdd440-4212-460b-8c32-7b01efe2dd94",
            "formatString": "#,0",
            "displayFolder": "Training"
          },
          {
            "name": "Trainings Delivered",
            "expression": [
              "COUNTROWS ( Training )"
            ],
            "lineageTag": "896a0797-ec0d-4812-8c8c-7804487eb1c3",
            "formatString": "#,0",
            "displayFolder": "Training"
          },
          {
            "name": "Training Completion %",
            "expression": [
              "DIVIDE ( CALCULATE ( COUNTROWS ( Training ), Training[CompletionStatus] = \"Completed\" ), COUNTROWS ( Training ) )"
            ],
            "lineageTag": "a3f88a43-6956-4aab-bd83-64fc0eb18869",
            "formatString": "0.0%",
            "displayFolder": "Training"
          },
          {
            "name": "Training Hours per Employee",
            "expression": [
              "DIVIDE ( [Training Hours], [Headcount] )"
            ],
            "lineageTag": "2b2d7824-84d6-4250-9298-dea27fe908de",
            "formatString": "0.0",
            "displayFolder": "Training"
          },
          {
            "name": "Leave Days",
            "expression": [
              "SUM ( 'Leave'[Days] )"
            ],
            "lineageTag": "3b54c6e6-d558-42b9-a915-f563f42acbf3",
            "formatString": "#,0",
            "displayFolder": "Leave"
          },
          {
            "name": "Sick Leave Days",
            "expression": [
              "CALCULATE ( SUM ( 'Leave'[Days] ), 'Leave'[LeaveType] = \"Sick\" )"
            ],
            "lineageTag": "a83c1b2e-6413-4afd-becf-8430f32ae069",
            "formatString": "#,0",
            "displayFolder": "Leave"
          },
          {
            "name": "Absenteeism %",
            "expression": [
              "DIVIDE ( [Sick Leave Days], [Headcount] * COUNTROWS ( VALUES ( 'Date'[MonthStart] ) ) * 22 )"
            ],
            "lineageTag": "cd9cf320-1766-441e-abe6-b55983fba346",
            "formatString": "0.00%",
            "displayFolder": "Leave"
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      }
    ],
